# Copiá este archivo a .env y completá los valores reales
# El archivo .env NO se sube al repo (está en .gitignore)

# Puerto del servidor (Railway/Render lo sobreescribe automáticamente)
PORT=4000

# Token secreto para el panel admin — OBLIGATORIO en producción
# Generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=CAMBIAR_POR_TOKEN_ALEATORIO_SEGURO

# Entorno: production | development
NODE_ENV=production
